# Core market selection
APP_SYMBOL=BTCUSD_PERP
APP_WS_BASE_URL=wss://dstream.binance.com
APP_REST_BASE_URL=https://dapi.binance.com
APP_DEPTH_LIMIT=1000
APP_ENABLE_DEPTH_STREAM=true
APP_ENABLE_BOOK_TICKER_STREAM=true
APP_ENABLE_AGG_TRADE_STREAM=true
APP_CANCEL_HEURISTIC=lifo
APP_HEALTH_REPORT_INTERVAL_SECS=30

# In-process NTP slew for recv_ts_ms correction
APP_NTP_SLEW_ENABLED=true
APP_NTP_SERVER=time.windows.com:123
APP_NTP_POLL_INTERVAL_SECS=30
APP_NTP_TIMEOUT_MS=1500
APP_NTP_SLEW_ALPHA=0.25
APP_NTP_SLEW_MAX_STEP_MS=25
# Hold depth until aggTrade watermark reaches depth_ts + look-ahead.
APP_EXECUTION_MATCH_LOOKAHEAD_MS=40
# Force open delayed depth attribution once lag exceeds this threshold.
APP_TRADE_ALIGNMENT_MAX_LAG_MS=250
# Hard reorder-buffer lag circuit breaker; triggers snapshot resync when exceeded.
APP_REORDER_RESYNC_MAX_LAG_MS=3000
# Local in-memory orderbook keyframe dump cadence; set 0 to disable periodic keyframes.
APP_SNAPSHOT_DUMP_INTERVAL_SECS=3600

# Throughput and local data paths
APP_CHANNEL_CAPACITY=20000
APP_DATA_ROOT=data
APP_RAW_SPOOL_DIR=data/raw
# Rows per raw parquet part (lower => less RAM per buffer, more files/uploads)
APP_RAW_PARQUET_CHUNK_ROWS=10000
APP_METRICS_DIR=data/metrics
APP_METRICS_RETENTION_DAYS=30

# Metrics backend options: jsonl | clickhouse
APP_METRICS_BACKEND=jsonl
APP_CLICKHOUSE_URL=http://127.0.0.1:8123
APP_CLICKHOUSE_DATABASE=crypto_monitor
APP_CLICKHOUSE_TABLE=metrics
APP_CLICKHOUSE_BATCH_SIZE=500
APP_CLICKHOUSE_FLUSH_MS=500

# S3 upload target root for daily archival datasets (bookTicker, depth-delta, snapshot, metrics).
# Use bucket+prefix (not the AWS Console URL).
# Example Console URL:
#   .../s3/buckets/crypto-datax1?...&prefix=binance_futures/COIN-M/bookTicker/
# maps to:
#   APP_S3_BUCKET=crypto-datax1
#   APP_S3_PREFIX=binance_futures/COIN-M/bookTicker
APP_S3_BUCKET=crypto-datax1
APP_S3_PREFIX=binance_futures/COIN-M/bookTicker

# AWS SDK credentials/region (used by uploader via default provider chain)
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
